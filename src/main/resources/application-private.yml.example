# =====================================================
# application-private.yml  (절대 git에 올리지 말 것)
# 이 파일을 복사해서 application-private.yml 로 저장하고
# 실제 값으로 채운 뒤 서버에 올린다.
# =====================================================

# ------ [공통] DB ------
spring:
  datasource:
    # 로컬 개발 예시
    #   url: jdbc:oracle:thin:@//localhost:1521/XEPDB1
    #   username: ARABICPT
    #   password: 로컬비밀번호
    #
    # 운영(OCI + Oracle Autonomous DB) 예시
    #   url: jdbc:oracle:thin:@adb.ap-seoul-1.oraclecloud.com:1522/abcdefg_high?wallet_location=/home/opc/wallet
    #   username: ARABICPT
    #   password: 운영비밀번호
    url: ${DB_URL:jdbc:oracle:thin:@//localhost:1521/XEPDB1}
    username: ${DB_USERNAME:ARABICPT}
    password: ${DB_PASSWORD:YOUR_DB_PASSWORD}

# ------ [공통] ElevenLabs TTS ------
elevenlabs:
  api-key: ${ELEVENLABS_API_KEY:sk_YOUR_ELEVENLABS_API_KEY}
  default-voice-id: ${ELEVENLABS_DEFAULT_VOICE_ID:YOUR_VOICE_ID}
  default-voice-name: ${ELEVENLABS_DEFAULT_VOICE_NAME:Salma}

# ------ [공통] 오디오 디렉터리 ------
app:
  # 로컬: uploads/audio  (프로젝트 상대 경로)
  # 운영: /home/opc/arabicpt/audio  (절대 경로, 재기동 후에도 유지)
  audio:
    upload-dir: ${APP_AUDIO_UPLOAD_DIR:uploads/audio}
    public-path: ${APP_AUDIO_PUBLIC_PATH:/audio}

  # 로컬: 두 origin 모두 허용
  # 운영: 실제 프론트엔드 도메인만 허용 (쉼표 구분)
  cors:
    allowed-origins: ${APP_CORS_ALLOWED_ORIGINS:http://localhost:5173,http://127.0.0.1:5173}
