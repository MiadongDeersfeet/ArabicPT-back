spring:
  datasource:
    url: ${DB_URL:jdbc:oracle:thin:@localhost:1521/XEPDB1}
    username: ${DB_USERNAME:YOUR_DB_USERNAME}
    password: ${DB_PASSWORD:YOUR_DB_PASSWORD}

security:
  jwt:
    secret: ${JWT_SECRET:YOUR_JWT_SECRET}
  oauth2:
    client-secret: ${OAUTH2_CLIENT_SECRET:YOUR_OAUTH2_CLIENT_SECRET}
